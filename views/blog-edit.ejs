<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/home.css" />
</head>
<body>

  <%- include("partials/header") %>

  <section class="blog-form-section">
    <div class="blog-form-box">
      <h2>✏️ Edit Blog</h2>

      <% if (locals.error) { %>
        <div class="error-message"><%= error %></div>
      <% } %>

      <form action="/blogs/<%= blog._id %>/edit" method="POST" enctype="multipart/form-data">

        <div class="form-group">
          <label>Blog Title</label>
          <input type="text" name="title" value="<%= blog.title %>" required>
        </div>

        <div class="form-group">
          <label>Content</label>
          <textarea name="content" rows="10" required><%= blog.content %></textarea>
        </div>

        <div class="form-group">
          <label>Cover Image</label>
          <% if (blog.coverImage) { %>
            <img src="/uploads/<%= blog.coverImage %>" alt="Current Cover"
              style="width:100%; max-height:200px; object-fit:cover; border-radius:10px; margin-bottom:8px;">
          <% } %>
          <input type="file" name="coverImage" accept="image/*" onchange="previewCover(this)">
          <img id="coverPreview" src="" alt=""
            style="max-width:100%; border-radius:10px; display:none; margin-top:8px;">
        </div>

        <div class="form-group">
          <label>Tags (comma separated)</label>
          <input type="text" name="tags" value="<%= blog.tags.join(', ') %>">
        </div>

        <div style="display:flex; gap:15px; justify-content:center; margin-top:10px;">
          <button type="submit" class="btn-primary1">Update Blog</button>
          <a href="/blogs/<%= blog._id %>" class="btn-secondary">Cancel</a>
        </div>

      </form>
    </div>
  </section>

  <%- include("partials/footer") %>

  <script>
    function previewCover(input) {
      const preview = document.getElementById("coverPreview");
      if (input.files && input.files[0]) {
        const reader = new FileReader();
        reader.onload = function(e) {
          preview.src = e.target.result;
          preview.style.display = "block";
        };
        reader.readAsDataURL(input.files[0]);
      }
    }
  </script>

</body>
</html>