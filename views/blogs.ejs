<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/home.css" />
</head>
<body>

  <%- include("partials/header") %>

  <section class="blogs-hero">
    <div class="hero-content">
      <h1>Student Blogs</h1>
      <p>Read, share and inspire with your fellow students.</p>
      <% if (user) { %>
        <a href="/blogs/create" class="btn-primary" style="margin-top: 15px; display:inline-block;">✏️ Write a Blog</a>
      <% } else { %>
        <a href="/signin" class="btn-primary" style="margin-top: 15px; display:inline-block;">Sign In to Write</a>
      <% } %>
    </div>
  </section>

  <div class="search-bar">
    <form action="/blogs/search" method="GET">
      <input
        type="text"
        name="q"
        placeholder="Search blogs by title, tag or keyword..."
        value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>"
      >
      <button type="submit">🔍 Search</button>
    </form>
  </div>

  <% if (typeof searchQuery !== 'undefined' && searchQuery) { %>
    <p class="search-info">
      Showing results for: <strong>"<%= searchQuery %>"</strong>
      (<%= blogs.length %> found)
      <a href="/blogs">✕ Clear</a>
    </p>
  <% } %>

  <section class="blogs">
    <h2><%= typeof searchQuery !== 'undefined' && searchQuery ? 'Search Results' : 'All Blogs' %></h2>

    <div class="blog-grid">
      <% if (blogs && blogs.length > 0) { %>
        <% blogs.forEach(blog => { %>
          <div class="blog-card">

            <% if (blog.coverImage) { %>
              <img src="/uploads/<%= blog.coverImage %>" alt="Cover"
                style="width:100%; height:180px; object-fit:cover; border-radius:10px; margin-bottom:12px;">
            <% } %>

            <h3><%= blog.title %></h3>
            <p><%= blog.content.substring(0, 120) %>...</p>

            <div class="blog-meta">
              <img src="/uploads/<%= blog.author.profilePic %>" alt="avatar"
                style="width:30px; height:30px; border-radius:50%; object-fit:cover;">
              <small>By <strong><%= blog.author.fullName %></strong></small>
              <small><%= new Date(blog.createdAt).toDateString() %></small>
            </div>

            <div class="blog-footer">
              <span>❤️ <%= blog.likes.length %></span>
              <span>💬 <%= blog.comments.length %></span>
              <a href="/blogs/<%= blog._id %>">Read More →</a>
            </div>

            <% if (blog.tags && blog.tags.length > 0) { %>
              <div class="blog-tags">
                <% blog.tags.forEach(tag => { %>
                  <span class="tag">#<%= tag %></span>
                <% }) %>
              </div>
            <% } %>

          </div>
        <% }) %>
      <% } else { %>
        <div class="no-blogs-box">
          <% if (typeof searchQuery !== 'undefined' && searchQuery) { %>
            <p>No blogs found for "<strong><%= searchQuery %></strong>"</p>
            <a href="/blogs" class="btn-primary">View All Blogs</a>
          <% } else { %>
            <p>No blogs yet. Be the first to write one!</p>
            <% if (user) { %>
              <a href="/blogs/create" class="btn-primary">✏️ Write First Blog</a>
            <% } %>
          <% } %>
        </div>
      <% } %>
    </div>
  </section>

  <%- include("partials/footer") %>

</body>
</html>