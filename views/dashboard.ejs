<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/home.css" />
</head>

<body>

  <%- include("partials/header") %>

  <section class="dashboard-section">


    <div class="dashboard-welcome">
      <img
        src="/uploads/<%= user.profilePic %>"
        alt="Profile"
        style="width:80px; height:80px; border-radius:50%; object-fit:cover; border:3px solid #4f46e5; margin-bottom:10px;">
      <h2>Welcome, <%= user.fullName %> 🎉</h2>
      <p>Here's your activity summary</p>
    </div>

    <div class="stats-grid">
      <div class="stat-card">
        <span class="stat-icon">📝</span>
        <h3><%= myBlogs.length %></h3>
        <p>Total Blogs</p>
      </div>
      <div class="stat-card">
        <span class="stat-icon">❤️</span>
        <h3><%= totalLikes %></h3>
        <p>Total Likes</p>
      </div>
      <div class="stat-card">
        <span class="stat-icon">💬</span>
        <h3><%= totalComments %></h3>
        <p>Total Comments</p>
      </div>
    </div>

    <div class="dashboard-actions">
      <a href="/blogs/create" class="btn-primary">✏️ Write New Blog</a>
      <a href="/profile" class="btn-secondary">👤 Profile</a>
      <a href="/blogs" class="btn-secondary">📚 All Blogs</a>
    </div>

    <div class="dashboard-blogs">
      <h3>Your Recent Blogs</h3>

      <% if (myBlogs && myBlogs.length > 0) { %>
        <div class="blog-grid">
          <% myBlogs.slice(0, 3).forEach(blog => { %>
            <div class="blog-card">

              <% if (blog.coverImage) { %>
                <img src="/uploads/<%= blog.coverImage %>" alt="Cover"
                  style="width:100%; height:150px; object-fit:cover; border-radius:10px; margin-bottom:10px;">
              <% } %>

              <h3><%= blog.title %></h3>
              <p><%= blog.content.substring(0, 100) %>...</p>

              <div class="blog-footer">

                <span>❤️ <%= blog.likes.length %></span>
                <span>💬 <%= blog.comments.length %></span>
                
              </div>

              <div style="display:flex; gap:8px; margin-top:10px;">
                <a href="/blogs/<%= blog._id %>" class="btn-primary" 
                  style="padding:6px 14px; font-size:0.85rem;">Read</a>
                <a href="/blogs/<%= blog._id %>/edit" class="btn-secondary"
                  style="padding:6px 14px; font-size:0.85rem;">Edit</a>
                <form action="/blogs/<%= blog._id %>/delete" method="POST" style="display:inline;">
                  <button class="btn-danger" style="margin:0; padding:6px 14px; font-size:0.85rem;"
                    onclick="return confirm('Delete this blog?')">Delete</button>
                </form>
              </div>

            </div>
          <% }) %>
        </div>

        <% if (myBlogs.length > 3) { %>
          <div style="text-align:center; margin-top:20px;">
            <a href="/blogs" class="btn-secondary">View All Your Blogs →</a>
          </div>
        <% } %>

      <% } else { %>
        <div class="no-blogs-box">
          <p>You haven't written any blogs yet!</p>
          <a href="/blogs/create" class="btn-primary">✏️ Write Your First Blog</a>
        </div>
      <% } %>

    </div>

  </section>

  <%- include("partials/footer") %>

</body>

</html>