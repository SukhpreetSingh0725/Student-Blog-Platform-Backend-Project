<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/home.css">
</head>
<body>

<%- include("partials/header") %>

<section class="about-hero">
  <div class="about-hero-content">
    <h1>About Student Blog Platform</h1>
    <p>
      A modern platform empowering students to share ideas,
      insights, and creativity through blogging.
    </p>
  </div>
</section>

<section class="about-section">
  <div class="about-container">

    <div class="about-card">
      <h2>🎯 Our Mission</h2>
      <p>
        To create a collaborative digital space where students
        can express knowledge, opinions, and innovative ideas.
      </p>
    </div>

    <div class="about-card">
      <h2>🚀 Our Vision</h2>
      <p>
        To become a leading student-driven blogging ecosystem
        that encourages learning and community growth.
      </p>
    </div>

    <div class="about-card">
      <h2>💡 Why This Platform?</h2>
      <p>
        Built using Node.js, Express, and EJS, this platform
        demonstrates full-stack backend architecture with
        scalable design principles.
      </p>
    </div>

  </div>
</section>

<section class="about-cta">
  <h2>Ready to Start Writing?</h2>
  <a href="/contact" class="btn-primary">Contact Us</a>
</section>

<%- include("partials/footer") %>

</body>
</html>